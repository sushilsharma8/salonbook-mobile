# API base URL (no trailing slash)
# IMPORTANT: use the canonical host that does NOT redirect.
# A host redirect (e.g. apex -> www) makes fetch drop the Authorization
# header, causing 401s on all authenticated requests.
# Production: https://www.bookursalon.in
# Android emulator: http://10.0.2.2:3000
# iOS simulator: http://localhost:3000
# Physical device: http://YOUR_LAN_IP:3000
EXPO_PUBLIC_API_URL=https://www.bookursalon.in
